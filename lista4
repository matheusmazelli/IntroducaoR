# RESPOSTA (6)

# Gráficos de dispersão que permitem descrever os padrões de associação entre o percentual de gordura (Fat) e as demais variáveis do banco de dados
for(i in names(medidas))
{  
if (i != "Fat")
{
plot(medidas[[i]],
medidas$Fat, 
xlab = i,
ylab = "Percentual de gordura (%)",
main = paste("Fat x", i),
pch = 16,           
col = "purple")  
}
}


# RESPOSTA (7)

# Coeficientes de correlação entre o percentual de gordura e as demais variáveis do banco de dados
coe <- cor(medidas)[,"Fat"]

# Listagem da tabela com os coeficientes de correlação
coe

# Leitura do resultado: As comparações apontam que as variáveis mais correlacionadas com o percentual de gordura são a densidade, de forma negativa, e o circunferência do abdômen, de forma positiva


# RESPOSTA (8)

# Análise sobre a tendência de pessoas mais idosas possuírem maior circunferência do abdômen
plot(
medidas$Age,
medidas$Abdomen,
xlab = "Idade (anos)",
ylab = "Circunferência do abdômen (cm)",
main = "Gráfico de dispersão entre a idade e a circunferência do abdômen das pessoas",
pch = 1,
col = "red"
)

# Coeficiente de correlação entre a idade e a circunferência do abdômen das pessoas
cor.test(
medidas$Age,
medidas$Abdomen
)

# Leitura do resultado: As comparações apontam que não há uma tendência de pessoas mais idosas possuírem maior circunferência do abdômen


