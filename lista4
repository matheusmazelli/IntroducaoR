# Removendo os objetos ativos
rm(list=ls())


# = EXERCÍCIO =

# Tabela com o banco de dados
medidas <- read.table("https://codeberg.org/edsonzmartinez/CursoR/raw/branch/main/antropo.txt")

# Promoção da primeira linha como cabeçalho (variáveis)
colnames(medidas) <- as.character(unlist(medidas[1, ]))

# Exclusão da primeira linha após o cabeçalho que ficou "duplicada"
medidas <- medidas[-1, ]

# Conversão dos dados em formato de texto para valores numéricos
medidas <- data.frame(lapply(medidas, as.numeric))

# Listagem da tabela com o banco de dados preparado
medidas


# RESPOSTA (1)

# Variável contendo os pesos das pessoas, em quilogramas
peso_kg <- medidas$Weight * 0.45359237

# Listagem da tabela com os pesos das pessoas em quilogramas
peso_kg


# RESPOSTA (2)


# Variável contendo as alturas das pessoas, em centímetros
altura_cm <- medidas$Height * 2.54

# Listagem da tabela com os pesos das pessoas em quilogramas
altura_cm


# RESPOSTA (3)

# Box-plot para cada uma das variáveis contínuas do banco de dados
boxplot(
medidas,
main = "Boxplot das variáveis contínuas do banco de dados",
las = 2
)


# RESPOSTA (4)

# Gráfico de dispersão entre o peso e a altura das pessoas, identificando valores atípicos nesta relação
plot(
medidas$Weight,
medidas$Height,
xlab = "Peso (libra)",
ylab = "Altura (polegada)",
main = "Gráfico da dispersão entre o peso e a altura das pessoas",
col = "blue"
)

# Leitura do resultado: Foram identificados quatro valores atípicos


