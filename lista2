# = EXERCÍCIO 1 =


# Endereço da tabela com os dados estatísticos dos jogadores
urlfile="https://raw.githubusercontent.com/edsonzmartinez/cursoR/main/Dados_jogadores.csv" 

# Tabela com os dados estatísticos dos jogadores
jog <- read.csv2(urlfile)

# Listagem da tabela com os dados estatísticos dos jogadores
jog


# RESPOSTA (1a)

# Coluna com as idades dos jogadores
ijog <- jog$idade

# Média das idades dos jogadores
mean(ijog)

# Desvio padrão das idades dos jogadores
sd(ijog)

# Mediana das idades dos jogadores
median(ijog)

# Amplitude das idades dos jogadores
range(ijog)

# Intervalo interquartil das idades dos jogadores
IQR(ijog)


# RESPOSTA (1b)

# Coluna com as alturas dos jogadores
ajog <- jog$altura

# Média das alturas dos jogadores com mais de 25 anos de idade
mean(ajog[ijog>25])

# Desvio padrão das alturas dos jogadores com mais de 25 anos de idade
sd(ajog[ijog>25])


# RESPOSTA (1c)

# Coluna com as posições dos jogadores
pjog <- jog$posicao

# Média das alturas dos jogadores por posição
aggregate(ajog, by=list(pjog), mean)

# Desvio padrão das alturas dos jogadores por posição
aggregate(ajog, by=list(pjog), sd)

# Mediana das alturas dos jogadores por posição
aggregate(ajog, by=list(pjog), median)


# RESPOSTA (1d)

# Coeficiente de correlação de Pearson entre idade e altura dos atletas
cor.test(ijog, ajog)
# Conclusão: correlação positiva, porém fraca. Não há uma tendência estatisticamente significativa para esta afirmação.


# RESPOSTA (1e)

#  Frequências absolutas dos jogadores por posição
table(pjog)

#  Frequências relativas dos jogadores por posição
prop.table(table(pjog))

