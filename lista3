# Removendo os objetos ativos
rm(list=ls())


# = EXERCÍCIO =


# Endereço da tabela com os dados climáticos de Ribeirão Preto, de 1991 a 2021
urlfile <- "https://codeberg.org/edsonzmartinez/CursoR/raw/branch/main/dadosclimaticosRP.csv" 

# Tabela com os dados climáticos de Ribeirão Preto, de 1991 a 2021
clima <- read.csv2(urlfile, fileEncoding = "Windows-1252")

# Listagem da tabela com os dados climáticos de Ribeirão Preto, de 1991 a 2021
clima


# RESPOSTA (a)

# Nomes das variáveis da base de dados
colnames(clima)


# RESPOSTA (b)

# Seis primeiras linhas da base de dados
head(clima, 6)


# RESPOSTA (c)

# Seis últimas linhas da base de dados
tail(clima, 6)


# RESPOSTA (d)

# Linhas 20 a 40 da base de dados
clima[20:40,]


# RESPOSTA (e)

#  Linhas correspondentes ao ano de 1993 da base de dados
clima[clima$ano == 1993,]


# RESPOSTA (f)

# Box-plot para a variável precipitação, mostrando quais são os meses com mais chuva e com menos chuva em Ribeirão Preto
boxplot(
clima$precipitacao ~ clima$mes,
names = c("JAN", "FEV", "MAR", "ABR", "MAI", "JUN", "JUL", "AGO", "SET", "OUT", "NOV", "DEZ"),
main = "Precipitação em Ribeirão Preto ao longo dos meses (1991-2021)",
xlab = "Mês",
ylab = "Precipitação",
)


# RESPOSTA (g)

# Código R para gerar uma figura igual à proposta no exercício

# Configuração prévia: números no eixo horizontal, legendas fora da área gráfica e definição das margens
par(
las = 1,
xpd = TRUE,
mar = c(7, 4, 4, 2)
)

# Definição do período inicial e do intervalo em meses, para temperaturas mínimas
tmin <- ts(
clima$tempmenmensal,
start = 1991,
frequency = 12
)

# Definição do período inicial e do intervalo em meses, para temperaturas máximas
tmax <- ts(
clima$tempmaxmensal,
start = 1991,
frequency = 12
)

# Criação e configuração do gráfico principal (temperatura máxima)
plot(
tmax,
type = "l",
col = "red",
ylim = c(0, 40),
bty = "n",
xaxt = "n",
yaxt = "n",
xlab = "",
ylab = "Temperatura (graus)",
main = "Temperaturas mensais em Ribeirão Preto, 1991 a 2021"
)

# Criação e configuração do gráfico secundário (temperatura mínima)
lines(
tmin,
col = "blue"
)

# Configuração do eixo horizontal
axis(
1,
at = 1991:2021,
labels = paste0("Jan\n", 1991:2021),
cex.axis = 0.6
)

# Configuração do eixo vertical no lado esquerdo com as marcações automáticas de temperatura
axis(
2
)

# Configuração das legendas abaixo do gráfico
legend(
"bottom",
inset = -0.25,
legend = c("Temperatura máxima", "Temperatura mínima"),
col = c("red", "blue"),
lty = 1,
bty = "n",
horiz = TRUE
)
