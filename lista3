clima$precipitacao ~ clima$mes,
names = c("JAN", "FEV", "MAR", "ABR", "MAI", "JUN", "JUL", "AGO", "SET", "OUT", "NOV", "DEZ"),
main = "Precipitação em Ribeirão Preto ao longo dos meses (1991-2021)",
xlab = "Mês",
ylab = "Precipitação",
)


