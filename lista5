rm(list=ls())


# = EXERCÍCIO - CRIANDO FUNÇÕES NO R =


# Glossário de variáveis:
# LDLc =  Colesterol da lipoproteína de baixa densidade
# CT = Colesterol total
# HDLc = HDL-colesterol
# VLDLc = VLDL-colesterol
# TG = Concentração de triglicerídeos


# Função para o cálculo do LDLc
fLDLc <- function(CT, HDLc, TG, jejum = TRUE)
{

# Equação proposta por Friedewald - cálculo do LDLc
# Levando-se em consideração se a pessoa fez ou não jejum
{
if(jejum) {LDLc <- CT - HDLc - (TG/5)}
else {LDLc <- CT - HDLc - (TG/8)}
}

# Verificação de precisão do resultado obtido
{
if(TG >= 400) {warning("Aviso: O resultado obtido é impreciso, pois o valor fornecido para TG >= 400 mg/dL.")}
}

# Estabelecimento de limite para TG em relação a jejum
{
lTG <- if(jejum) 150 else 175
}

# Condição para hiperlipidemia mista
{
if(LDLc >= 160 && TG >= lTG) {warning("Aviso: As concentrações informadas para LDLc e TG indicam hiperlipidemia mista.")}
}

# Condição para hipercolesterolemia isolada
{
if(LDLc > 160 && TG < lTG) {warning("Aviso: A concentração informada para LDLc indica hipercolesterolemia isolada.")}
}

# Resultado do cálculo do LDLc
return(LDLc)
}

# Sintaxe da função criada
fLDLc(CT, HDLc, TG, jejum = TRUE)
